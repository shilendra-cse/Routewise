{
  "name": "routewise",
  "version": "0.0.1",
  "description": "Your folders are your API.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"test/**/*.test.ts\"",
    "dev": "npm run dev --prefix examples/basic-api",
    "example:node": "npm run start --prefix examples/basic-api",
    "example:bun": "bun examples/basic-api/main.ts",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web",
    "web:start": "npm run start --prefix web"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shilendra-cse/Routewise.git"
  },
  "bugs": {
    "url": "https://github.com/shilendra-cse/Routewise/issues"
  },
  "homepage": "https://github.com/shilendra-cse/Routewise#readme",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
